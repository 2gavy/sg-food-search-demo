# Elastic Cloud Serverless Search project
ELASTICSEARCH_URL=https://your-project.es.region.aws.elastic.cloud:443
KIBANA_URL=https://your-project.kb.region.aws.elastic.cloud:443
ES_API_KEY=your-elasticsearch-api-key

# EIS inference endpoints
INFERENCE_ENDPOINT_ID=.jina-embeddings-v5-omni-small
# Open-source contrast: multilingual-e5-small (384-dim, Apache 2.0)
# Default pre-provisioned ID on Serverless; run scripts/setup_inference_oss.py to verify/create
INFERENCE_ENDPOINT_OSS_ID=.multilingual-e5-small-elasticsearch

# Index names
CORPUS_INDEX=sg_food_corpus_current
CASES_INDEX=sg_food_hunt_cases

# Agent Builder — Serverless preconfigured LLM (see Kibana → Connectors)
# Examples on Serverless Search: Anthropic-Claude-Sonnet-4-6, Google-Gemini-2-5-Flash, OpenAI-GPT-4-1
LLM_CONNECTOR_ID=Anthropic-Claude-Sonnet-4-6
AGENT_BUILDER_AGENT_ID=sg-food-concierge

# Web / API
API_HOST=127.0.0.1
API_PORT=8000

# Cloud Run: set ELASTICSEARCH_URL, ES_API_KEY (and optional vars below) in the
# Cloud Run console — see docs/CLOUD_RUN_CONSOLE.md. Do not bake .env into the image.

# Map (optional — Leaflet/OSM works without a token)
MAPBOX_ACCESS_TOKEN=
